@echo off
setlocal
set "ROOT=%~dp0.."
where bash >nul 2>nul
if errorlevel 1 (
  echo plugin-kit-ai launcher: bash not found >&2
  exit /b 1
)
set "_ARGS="
:collect_args
if "%~1"=="" goto run_launcher
set "_ARGS=%_ARGS% "%~1""
shift
goto collect_args
:run_launcher
bash "%ROOT%\scripts\main.sh"%_ARGS%
exit /b %ERRORLEVEL%
