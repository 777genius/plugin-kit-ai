{
  "linear": {
    "headers": {
      "Authorization": "Bearer ${LINEAR_API_KEY}"
    },
    "type": "sse",
    "url": "https://mcp.linear.app/mcp"
  },
  "playwright": {
    "args": [
      "-y",
      "@playwright/mcp@0.0.70"
    ],
    "command": "npx"
  },
  "supabase": {
    "headers": {
      "Authorization": "Bearer ${SUPABASE_ACCESS_TOKEN}"
    },
    "type": "sse",
    "url": "https://mcp.supabase.com/mcp?project_ref=${SUPABASE_PROJECT_REF}"
  }
}
