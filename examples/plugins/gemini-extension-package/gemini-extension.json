{
  "contextFileName": "GEMINI.md",
  "description": "Reference Gemini CLI extension package",
  "excludeTools": [
    "run_shell_command(rm -rf)"
  ],
  "mcpServers": {
    "release-checks": {
      "args": [
        "${extensionPath}/bin/release-checks.mjs"
      ],
      "command": "node"
    }
  },
  "migratedTo": "https://github.com/plugin-kit-ai/example-gemini-extension-v2",
  "name": "gemini-extension-package",
  "plan": {
    "directory": ".gemini/plans",
    "retentionDays": 7
  },
  "settings": [
    {
      "description": "Deployment profile used by local extension lifecycle checks.",
      "envVar": "RELEASE_PROFILE",
      "name": "release-profile",
      "sensitive": false
    }
  ],
  "themes": [
    {
      "background": {
        "diff": {
          "added": "#edf7ed",
          "removed": "#fdecec"
        },
        "primary": "#fff9f2"
      },
      "name": "release-dawn",
      "status": {
        "error": "#b42318",
        "success": "#18794e",
        "warning": "#9a6700"
      },
      "text": {
        "accent": "#b3571f",
        "link": "#8f4d1f",
        "primary": "#2e1f14",
        "secondary": "#6f5a4a"
      },
      "ui": {
        "active": "#b3571f",
        "comment": "#6f5a4a",
        "focus": "#18794e",
        "gradient": [
          "#b3571f",
          "#d99058",
          "#f3c48b"
        ]
      }
    }
  ],
  "version": "0.1.0",
  "x_galleryTopic": "gemini-cli-extension"
}
